[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/mission_complete_screen.gd" id="1_mission_done"]

[node name="MissionComplete" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_mission_done")

[node name="ColorRect" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.06, 0.14, 0.08, 1)

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 20
alignment = 1

[node name="Title" type="Label" parent="CenterContainer/VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.2, 0.95, 0.4, 1)
theme_override_font_sizes/font_size = 40
text = "MISSÃO CUMPRIDA!"
horizontal_alignment = 1

[node name="Stats" type="Label" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(500, 0)
layout_mode = 2
theme_override_colors/font_color = Color(0.8, 0.9, 0.8, 1)
theme_override_font_sizes/font_size = 16
text = "Pilotos perdidos: 0"
horizontal_alignment = 1
autowrap_mode = 2

[node name="Control" type="Control" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(0, 10)
layout_mode = 2

[node name="NextButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(260, 50)
layout_mode = 2
text = "PRÓXIMA MISSÃO"

[node name="MenuButton" type="Button" parent="CenterContainer/VBoxContainer"]
custom_minimum_size = Vector2(260, 40)
layout_mode = 2
text = "MENU PRINCIPAL"

[connection signal="pressed" from="CenterContainer/VBoxContainer/NextButton" to="." method="_on_next_button_pressed"]
[connection signal="pressed" from="CenterContainer/VBoxContainer/MenuButton" to="." method="_on_menu_button_pressed"]
